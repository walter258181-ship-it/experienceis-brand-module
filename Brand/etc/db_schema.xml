<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <table name="experienceis_brand" resource="default" engine="innodb" comment="Experienceis Brand Table">

        <column xsi:type="int" name="brand_id" nullable="false" identity="true" unsigned="true" comment="Brand ID"/>

        <column xsi:type="varchar" name="name" nullable="false" length="255" comment="Name"/>
        <column xsi:type="text" name="description" nullable="true" comment="Description"/>
        <column xsi:type="varchar" name="logo" nullable="true" length="255" comment="Logo"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="brand_id"/>
        </constraint>

    </table>
</schema>