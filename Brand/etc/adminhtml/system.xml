<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system.xsd">
    <system>
        
        <tab id="experienceis" translate="label" sortOrder="100">
            <label>Experienceis</label>
        </tab>
        <section id="experienceis_brand" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Brand Configuration</label>
            <tab>experienceis</tab>
            <resource>Experienceis_Brand::config</resource>

            <group id="general" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General Settings</label>
                
                <field id="enabled" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Brand Display in Frontend</label>
                    <comment>If set to No, the brand information will not be displayed on the product page.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>
        </section>
    </system>
</config>
