<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">
                experienceis_brand_brand_listing.experienceis_brand_brand_listing_data_source
            </item>
        </item>
    </argument>

    <settings>

        <buttons>
            <button name="add">
                <url path="*/*/edit"/>
                <class>primary</class>
                <label translate="true">Add New Brand</label>
            </button>
        </buttons>

        <spinner>experienceis_brand_columns</spinner>

        <deps>
            <dep>
                experienceis_brand_brand_listing.experienceis_brand_brand_listing_data_source
            </dep>
        </deps>

    </settings>

    <dataSource name="experienceis_brand_brand_listing_data_source"
                component="Magento_Ui/js/grid/provider">

        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">brand_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>

      <dataProvider class="Experienceis\Brand\Ui\Component\Form\BrandDataProvider" name="experienceis_brand_brand_listing_data_source">
    <settings>
        <requestFieldName>brand_id</requestFieldName>
        <primaryFieldName>brand_id</primaryFieldName>
    </settings>
</dataProvider>


    </dataSource>

    <columns name="experienceis_brand_columns">

        <column name="brand_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>

        <column name="name">
            <settings>
                <filter>text</filter>
                <label translate="true">Name</label>
            </settings>
        </column>

        <column name="description">
            <settings>
                <filter>text</filter>
                <label translate="true">Description</label>
            </settings>
        </column>
        <column name="logo"
        class="Experienceis\Brand\Ui\Component\Listing\Column\Thumbnail"
        component="Magento_Ui/js/grid/columns/thumbnail">
            <settings>
        <label translate="true">Logo</label>
        <sortable>false</sortable>
             </settings>
         </column>
        <actionsColumn name="actions"
        class="Experienceis\Brand\Ui\Component\Listing\Column\BrandActions">
          <settings>
            <indexField>brand_id</indexField>
          </settings>
        </actionsColumn>
        

    </columns>

</listing>